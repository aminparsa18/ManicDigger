<!--
    GameView.xaml
    ═════════════
    Two-layer host:
      [0] SKGLView          — game render, always present, fills the window
      [1] OverlayMenuView   — pause / options UI, hidden until ESC pressed

    All overlay logic lives in OverlayMenuView.xaml / OverlayMenuView.xaml.cs.
    This file intentionally has no resource dictionary — styles belong to the
    view that uses them.
-->
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:skia="clr-namespace:SkiaSharp.Views.Maui.Controls;assembly=SkiaSharp.Views.Maui.Controls"
             xmlns:views="clr-namespace:MeinKraft.Maui.Views"
             x:Class="MeinKraft.Maui.Views.GameView"
             Shell.NavBarIsVisible="False">

    <!--
        Root Grid — two stacked layers at the same cell (no row/column defs needed).
        The overlay sits on top and captures all input while visible.
    -->
    <Grid>

        <!-- ── Layer 0: Game canvas ──────────────────────────────────────── -->
        <skia:SKGLView x:Name="GlView"
                       IsVisible="True"
                       HorizontalOptions="Fill"
                       VerticalOptions="Fill"
                       HasRenderLoop="False" />

        <!-- ── Layer 1: Pause / options overlay ─────────────────────────── -->
        <!--
            Toggled by ShowPauseMenu() / HideOverlay() in GameView.xaml.cs.
            While IsVisible=True the overlay captures all pointer/touch input;
            the game canvas below receives nothing.
        -->

        <views:SetupProgressView x:Name="ProgressView"
                                 HorizontalOptions="Fill"
                                 VerticalOptions="Fill"/>
        
        <views:OverlayMenuView x:Name="OverlayMenu"
                               IsVisible="False"
                               HorizontalOptions="Fill"
                               VerticalOptions="Fill" />
        

    </Grid>

</ContentPage>
