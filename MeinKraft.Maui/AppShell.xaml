<Shell
    x:Class="MeinKraft.Maui.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:MeinKraft.Maui.Views"
    Title="MeinKraft.Maui"
    FlyoutBehavior="Disabled">

    <ShellContent
        Title="Menu"
        ContentTemplate="{DataTemplate local:MainMenuView}"
        Route="MainMenuView" />

    <ShellContent
         Title="SinglePlayer"
         ContentTemplate="{DataTemplate local:SinglePlayerView}"
         Route="SinglePlayerView" />

    <ShellContent
         Title="Home"
         ContentTemplate="{DataTemplate local:GameView}"
         Route="GameView" />

</Shell>
