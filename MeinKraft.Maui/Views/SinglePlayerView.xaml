<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MeinKraft.Maui.Views.SinglePlayerView"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#0a0a0a">

    <ContentPage.Resources>
        <ResourceDictionary>

            <Style x:Key="SlotBorder" TargetType="Border">
                <Setter Property="VisualStateManager.VisualStateGroups">
                    <Setter.Value>
                        <VisualStateGroupList>
                            <VisualStateGroup x:Name="CommonStates">

                                <VisualState x:Name="Normal">
                                    <VisualState.Setters>
                                        <Setter Property="Scale" Value="1.0" />
                                    </VisualState.Setters>
                                </VisualState>

                                <VisualState x:Name="PointerOver">
                                    <VisualState.Setters>
                                        <Setter Property="Scale" Value="1.03" />
                                    </VisualState.Setters>
                                </VisualState>

                                <VisualState x:Name="Pressed">
                                    <VisualState.Setters>
                                        <Setter Property="Scale" Value="0.97" />
                                    </VisualState.Setters>
                                </VisualState>

                                <VisualState x:Name="Disabled">
                                    <VisualState.Setters>
                                        <Setter Property="Opacity" Value="0.4" />
                                    </VisualState.Setters>
                                </VisualState>

                            </VisualStateGroup>
                        </VisualStateGroupList>
                    </Setter.Value>
                </Setter>
            </Style>

        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid>

        <Image Source="background.png"
               Aspect="AspectFill"
               HorizontalOptions="Fill"
               VerticalOptions="Fill" />

        <BoxView HorizontalOptions="Fill" VerticalOptions="Fill">
            <BoxView.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#66000000" Offset="0.0" />
                    <GradientStop Color="#dd000000" Offset="1.0" />
                </LinearGradientBrush>
            </BoxView.Background>
        </BoxView>

        <Grid RowDefinitions="Auto,Auto,*,Auto,Auto"
              Padding="24,32,24,28">

            <!-- Title -->
            <VerticalStackLayout Grid.Row="0" Spacing="4">
                <Label Text="SINGLEPLAYER"
                       FontFamily="PressStart2PRegular"
                       FontSize="20"
                       TextColor="{StaticResource GrassGreen}"
                       HorizontalOptions="Center"
                       CharacterSpacing="4">
                    <Label.Shadow>
                        <Shadow Brush="#1a1a1a" Offset="3,3" Radius="0" Opacity="1" />
                    </Label.Shadow>
                </Label>
                <Label Text="choose a world or create a new one"
                       FontFamily="PressStart2PRegular"
                       FontSize="6"
                       TextColor="{StaticResource TextDim}"
                       HorizontalOptions="Center"
                       CharacterSpacing="1" />
            </VerticalStackLayout>

            <BoxView Grid.Row="1" Style="{StaticResource Divider}" Margin="0,14,0,14" />

            <!-- World list area -->
            <Grid Grid.Row="2">

                <!-- Loading state -->
                <VerticalStackLayout x:Name="LoadingState"
                                     IsVisible="True"
                                     VerticalOptions="Center"
                                     HorizontalOptions="Center"
                                     Spacing="16">
                    <ActivityIndicator Color="{StaticResource GrassGreen}"
                                       IsRunning="True"
                                       WidthRequest="28"
                                       HeightRequest="28"
                                       HorizontalOptions="Center" />
                    <Label Text="loading worlds..."
                           FontFamily="PressStart2PRegular"
                           FontSize="6"
                           TextColor="{StaticResource TextDim}"
                           HorizontalOptions="Center" />
                </VerticalStackLayout>

                <!-- Empty state -->
                <VerticalStackLayout x:Name="EmptyState"
                                     IsVisible="False"
                                     VerticalOptions="Center"
                                     HorizontalOptions="Center"
                                     Spacing="12">
                    <Label Text="[ NO WORLDS FOUND ]"
                           FontFamily="PressStart2PRegular"
                           FontSize="9"
                           TextColor="#44ffffff"
                           HorizontalOptions="Center" />
                    <Label Text="Press NEW WORLD below to get started"
                           FontFamily="PressStart2PRegular"
                           FontSize="6"
                           TextColor="#33ffffff"
                           HorizontalOptions="Center" />
                </VerticalStackLayout>

                <!-- Error state -->
                <VerticalStackLayout x:Name="ErrorState"
                                     IsVisible="False"
                                     VerticalOptions="Center"
                                     HorizontalOptions="Center"
                                     Spacing="16">
                    <Label x:Name="ErrorLabel"
                           FontFamily="PressStart2PRegular"
                           FontSize="7"
                           TextColor="#cc6666"
                           HorizontalOptions="Center"
                           HorizontalTextAlignment="Center" />
                    <Border Style="{StaticResource VoxelButtonBevel}">
                        <Button Style="{StaticResource VoxelButton}"
                                Text="RETRY"
                                Clicked="OnRetryClicked" />
                    </Border>
                </VerticalStackLayout>

                <!-- World list -->
                <CollectionView x:Name="WorldList"
                                IsVisible="False"
                                SelectionMode="None"
                                VerticalOptions="Fill">
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Vertical" ItemSpacing="10" />
                    </CollectionView.ItemsLayout>

                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <!-- Bevel frame -->
                            <Border StrokeThickness="0"
                                    Padding="3"
                                    HorizontalOptions="Fill"
                                    Style="{StaticResource SlotBorder}">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="{StaticResource StoneEdgeTop}"    Offset="0.0" />
                                        <GradientStop Color="{StaticResource StoneEdgeBottom}" Offset="1.0" />
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Border.Shadow>
                                    <Shadow Brush="#000000" Offset="4,4" Radius="0" Opacity="0.8" />
                                </Border.Shadow>

                                <!-- Face -->
                                <Border StrokeThickness="0"
                                        HeightRequest="62"
                                        HorizontalOptions="Fill">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#7a7a7a" Offset="0.0"  />
                                            <GradientStop Color="#525252" Offset="0.45" />
                                            <GradientStop Color="#424242" Offset="0.55" />
                                            <GradientStop Color="#303030" Offset="1.0"  />
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=PlaySlotCommand}"
                                            CommandParameter="{Binding .}" />
                                    </Border.GestureRecognizers>

                                    <Grid ColumnDefinitions="48,*,48"
                                          Padding="12,0,4,0">

                                        <!-- Dirt/grass block icon -->
                                        <Border Grid.Column="0"
                                                WidthRequest="32" HeightRequest="32"
                                                StrokeThickness="2"
                                                Stroke="#5d9e29"
                                                VerticalOptions="Center"
                                                InputTransparent="True">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                    <GradientStop Color="#5d9e29" Offset="0.0"  />
                                                    <GradientStop Color="#5d9e29" Offset="0.25" />
                                                    <GradientStop Color="#7a4a2a" Offset="0.25" />
                                                    <GradientStop Color="#5a3010" Offset="1.0"  />
                                                </LinearGradientBrush>
                                            </Border.Background>
                                        </Border>

                                        <!-- World name + last played -->
                                        <VerticalStackLayout Grid.Column="1"
                                                             VerticalOptions="Center"
                                                             Spacing="4"
                                                             InputTransparent="True"
                                                             Padding="10,0,0,0">
                                            <Label Text="{Binding Name}"
                                                   FontFamily="PressStart2PRegular"
                                                   FontSize="9"
                                                   TextColor="{StaticResource TextWhite}"
                                                   LineBreakMode="TailTruncation" />
                                            <Label Text="{Binding LastPlayedText}"
                                                   FontFamily="PressStart2PRegular"
                                                   FontSize="6"
                                                   TextColor="{StaticResource TextDim}" />
                                        </VerticalStackLayout>

                                        <!-- Delete -->
                                        <Button Grid.Column="2"
                                                Text="✕"
                                                FontSize="13"
                                                TextColor="#cc6666"
                                                BackgroundColor="Transparent"
                                                BorderWidth="0"
                                                CornerRadius="0"
                                                WidthRequest="44"
                                                HeightRequest="44"
                                                VerticalOptions="Center"
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=DeleteSlotCommand}"
                                                CommandParameter="{Binding .}" />

                                    </Grid>
                                </Border>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

            </Grid>

            <!-- Status label -->
            <Label Grid.Row="3"
                   x:Name="StatusLabel"
                   IsVisible="False"
                   FontFamily="PressStart2PRegular"
                   FontSize="6"
                   HorizontalOptions="Center"
                   Margin="0,10,0,0"
                   TextColor="{StaticResource GrassGreen}" />

            <!-- Footer: Back | New World -->
            <Grid Grid.Row="4"
                  ColumnDefinitions="*,16,*"
                  Margin="0,16,0,0">

                <Border Grid.Column="0" Style="{StaticResource VoxelButtonBevel}">
                    <Button Style="{StaticResource VoxelButton}"
                            Text="◀  Back"
                            Clicked="OnBackClicked">
                        <Button.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#7a7a7a" Offset="0.0"  />
                                <GradientStop Color="#525252" Offset="0.45" />
                                <GradientStop Color="#424242" Offset="0.55" />
                                <GradientStop Color="#303030" Offset="1.0"  />
                            </LinearGradientBrush>
                        </Button.Background>
                    </Button>
                </Border>

                <Border Grid.Column="2"
                        StrokeThickness="0"
                        Padding="3">
                    <Border.Shadow>
                        <Shadow Brush="#000000" Offset="4,4" Radius="0" Opacity="0.85" />
                    </Border.Shadow>
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#7ecf38" Offset="0.0" />
                            <GradientStop Color="#2a4a10" Offset="1.0" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <Button Style="{StaticResource VoxelButton}"
                            Text="+ New World"
                            Clicked="OnNewWorldClicked">
                        <Button.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#6ab82e" Offset="0.0"  />
                                <GradientStop Color="#4a8a1e" Offset="0.45" />
                                <GradientStop Color="#3a6a14" Offset="0.55" />
                                <GradientStop Color="#244a0a" Offset="1.0"  />
                            </LinearGradientBrush>
                        </Button.Background>
                    </Button>
                </Border>

            </Grid>
        </Grid>
    </Grid>
</ContentPage>
