<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:cmp="clr-namespace:MeinKraft.Maui.Views.Components"
             x:Class="MeinKraft.Maui.Views.SetupProgressView">
    <Grid VerticalOptions="Fill">

        <!-- ── Dim backdrop ──────────────────────────────────────────────── -->
        <BoxView HorizontalOptions="Fill" VerticalOptions="Fill"
             InputTransparent="True">
            <BoxView.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#88000000" Offset="0.0" />
                    <GradientStop Color="#bb000000" Offset="1.0" />
                </LinearGradientBrush>
            </BoxView.Background>
        </BoxView>
        
        <cmp:VoxelIndicator x:Name="Title" IsRunning="True" VerticalOptions="Center" />
        
    </Grid>
</ContentView>
