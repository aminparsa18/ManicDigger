<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MeinKraft.Maui.Views.SinglePlayerView"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#0a0a0a">

    <ContentPage.Resources>
        <ResourceDictionary>

            <Color x:Key="StoneEdgeTop">#aaaaaa</Color>
            <Color x:Key="StoneEdgeBottom">#2a2a2a</Color>
            <Color x:Key="GrassGreen">#5d9e29</Color>
            <Color x:Key="TextWhite">#f0ece0</Color>
            <Color x:Key="TextDim">#aaaaaa</Color>

            <!-- Shared bevel frame -->
            <Style x:Key="VoxelButtonBevel" TargetType="Border">
                <Setter Property="StrokeThickness"   Value="0" />
                <Setter Property="Padding"           Value="3" />
                <Setter Property="HorizontalOptions" Value="Center" />
                <Setter Property="Shadow">
                    <Setter.Value>
                        <Shadow Brush="#000000" Offset="4,4" Radius="0" Opacity="0.85" />
                    </Setter.Value>
                </Setter>
                <Setter Property="Background">
                    <Setter.Value>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="{StaticResource StoneEdgeTop}"    Offset="0.0" />
                            <GradientStop Color="{StaticResource StoneEdgeBottom}" Offset="1.0" />
                        </LinearGradientBrush>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Action button (Back / New World) -->
            <Style x:Key="VoxelButton" TargetType="Button">
                <Setter Property="FontFamily"        Value="PressStart2PRegular" />
                <Setter Property="FontSize"          Value="10" />
                <Setter Property="TextColor"         Value="{StaticResource TextWhite}" />
                <Setter Property="WidthRequest"      Value="260" />
                <Setter Property="HeightRequest"     Value="44" />
                <Setter Property="CornerRadius"      Value="0" />
                <Setter Property="BorderWidth"       Value="0" />
                <Setter Property="Padding"           Value="0" />
                <Setter Property="Shadow">
                    <Setter.Value>
                        <Shadow Brush="#000000" Offset="3,3" Radius="0" Opacity="0.9" />
                    </Setter.Value>
                </Setter>

                <Setter Property="VisualStateManager.VisualStateGroups">
                    <Setter.Value>
                        <VisualStateGroupList>
                            <VisualStateGroup x:Name="CommonStates">

                                <VisualState x:Name="Normal">
                                    <VisualState.Setters>
                                        <Setter Property="TextColor" Value="{StaticResource TextWhite}" />
                                        <Setter Property="Scale" Value="1.0" />
                                    </VisualState.Setters>
                                </VisualState>
                                
                                <!-- PointerOver — brighter stone, yellow text (classic Minecraft hover) -->
                                <VisualState x:Name="PointerOver">
                                    <VisualState.Setters>
                                        <Setter Property="TextColor" Value="#ffee55" />
                                        <Setter Property="Scale" Value="1.03" />
                                    </VisualState.Setters>
                                </VisualState>

                                <!-- Pressed — inverted bevel, slight scale-down for tactile feel -->
                                <VisualState x:Name="Pressed">
                                    <VisualState.Setters>
                                        <Setter Property="TextColor" Value="#ccbb33" />
                                        <Setter Property="Scale" Value="0.97" />
                                    </VisualState.Setters>
                                </VisualState>

                                <VisualState x:Name="Disabled">
                                    <VisualState.Setters>
                                        <Setter Property="TextColor" Value="#555555" />
                                        <Setter Property="Opacity"   Value="0.4" />
                                    </VisualState.Setters>
                                </VisualState>

                            </VisualStateGroup>
                        </VisualStateGroupList>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Grass-green fading divider -->
            <Style x:Key="Divider" TargetType="BoxView">
                <Setter Property="HeightRequest"     Value="2" />
                <Setter Property="HorizontalOptions" Value="Fill" />
                <Setter Property="Background">
                    <Setter.Value>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="Transparent"                Offset="0.0" />
                            <GradientStop Color="{StaticResource GrassGreen}" Offset="0.5" />
                            <GradientStop Color="Transparent"                Offset="1.0" />
                        </LinearGradientBrush>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="SlotBorder" TargetType="Border">
                <Setter Property="VisualStateManager.VisualStateGroups">
                    <Setter.Value>
                        <VisualStateGroupList>
                            <VisualStateGroup x:Name="CommonStates">

                                <VisualState x:Name="Normal">
                                    <VisualState.Setters>
                                        <Setter Property="Scale" Value="1.0" />
                                    </VisualState.Setters>
                                </VisualState>

                                <!-- PointerOver — brighter stone, yellow text (classic Minecraft hover) -->
                                <VisualState x:Name="PointerOver">
                                    <VisualState.Setters>
                                        <Setter Property="Scale" Value="1.03" />
                                    </VisualState.Setters>
                                </VisualState>

                                <!-- Pressed — inverted bevel, slight scale-down for tactile feel -->
                                <VisualState x:Name="Pressed">
                                    <VisualState.Setters>
                                        <Setter Property="Scale" Value="0.97" />
                                    </VisualState.Setters>
                                </VisualState>

                                <VisualState x:Name="Disabled">
                                    <VisualState.Setters>
                                        <Setter Property="Opacity" Value="0.4" />
                                    </VisualState.Setters>
                                </VisualState>

                            </VisualStateGroup>
                        </VisualStateGroupList>
                    </Setter.Value>
                </Setter>
            </Style>

        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid>

        <Image Source="background.png"
               Aspect="AspectFill"
               HorizontalOptions="Fill"
               VerticalOptions="Fill" />

        <BoxView HorizontalOptions="Fill" VerticalOptions="Fill">
            <BoxView.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#66000000" Offset="0.0" />
                    <GradientStop Color="#dd000000" Offset="1.0" />
                </LinearGradientBrush>
            </BoxView.Background>
        </BoxView>

        <Grid RowDefinitions="Auto,Auto,*,Auto"
              Padding="24,32,24,28">

            <!-- Title -->
            <VerticalStackLayout Grid.Row="0" Spacing="4">
                <Label Text="SINGLEPLAYER"
                       FontFamily="PressStart2PRegular"
                       FontSize="20"
                       TextColor="{StaticResource GrassGreen}"
                       HorizontalOptions="Center"
                       CharacterSpacing="4">
                    <Label.Shadow>
                        <Shadow Brush="#1a1a1a" Offset="3,3" Radius="0" Opacity="1" />
                    </Label.Shadow>
                </Label>
                <Label Text="choose a world or create a new one"
                       FontFamily="PressStart2PRegular"
                       FontSize="6"
                       TextColor="{StaticResource TextDim}"
                       HorizontalOptions="Center"
                       CharacterSpacing="1" />
            </VerticalStackLayout>

            <BoxView Grid.Row="1" Style="{StaticResource Divider}" Margin="0,14,0,14" />

            <!-- Save slot list -->
            <Grid Grid.Row="2">

                <!-- Empty state -->
                <VerticalStackLayout x:Name="EmptyState"
                                     IsVisible="False"
                                     VerticalOptions="Center"
                                     HorizontalOptions="Center"
                                     Spacing="12">
                    <Label Text="[ NO WORLDS FOUND ]"
                           FontFamily="PressStart2PRegular"
                           FontSize="9"
                           TextColor="#44ffffff"
                           HorizontalOptions="Center" />
                    <Label Text="Press NEW WORLD below to get started"
                           FontFamily="PressStart2PRegular"
                           FontSize="6"
                           TextColor="#33ffffff"
                           HorizontalOptions="Center" />
                </VerticalStackLayout>

                <!--
                    Each row: bevel Border (fixed) wrapping a face Border (stone gradient).
                    TapGestureRecognizer on the face triggers slot load.
                    The delete Button sits in its own column and calls OnDeleteClicked.
                    Both pass the SaveSlot as CommandParameter via BindingContext.
                -->
                <CollectionView x:Name="SaveSlotList"
                                SelectionMode="None"
                                VerticalOptions="Fill">
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Vertical" ItemSpacing="10" />
                    </CollectionView.ItemsLayout>

                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <!-- Bevel frame — never scaled -->
                            <Border StrokeThickness="0"
                                    Padding="3"
                                    HorizontalOptions="Fill"
                                    Style="{StaticResource SlotBorder}">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="{StaticResource StoneEdgeTop}"    Offset="0.0" />
                                        <GradientStop Color="{StaticResource StoneEdgeBottom}" Offset="1.0" />
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Border.Shadow>
                                    <Shadow Brush="#000000" Offset="4,4" Radius="0" Opacity="0.8" />
                                </Border.Shadow>

                                <!-- Face — carries the tap gesture -->
                                <Border StrokeThickness="0"
                                        HeightRequest="62"
                                        HorizontalOptions="Fill">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#7a7a7a" Offset="0.0"  />
                                            <GradientStop Color="#525252" Offset="0.45" />
                                            <GradientStop Color="#424242" Offset="0.55" />
                                            <GradientStop Color="#303030" Offset="1.0"  />
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=LoadSlotCommand}"
                                            CommandParameter="{Binding .}" />
                                    </Border.GestureRecognizers>

                                    <Grid ColumnDefinitions="48,*,48"
                                          Padding="12,0,4,0">

                                        <!-- Dirt/grass block icon -->
                                        <Border Grid.Column="0"
                                                WidthRequest="32" HeightRequest="32"
                                                StrokeThickness="2"
                                                Stroke="#5d9e29"
                                                VerticalOptions="Center"
                                                InputTransparent="True">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                    <GradientStop Color="#5d9e29" Offset="0.0"  />
                                                    <GradientStop Color="#5d9e29" Offset="0.25" />
                                                    <GradientStop Color="#7a4a2a" Offset="0.25" />
                                                    <GradientStop Color="#5a3010" Offset="1.0"  />
                                                </LinearGradientBrush>
                                            </Border.Background>
                                        </Border>

                                        <!-- World name + last played -->
                                        <VerticalStackLayout Grid.Column="1"
                                                             VerticalOptions="Center"
                                                             Spacing="4"
                                                             InputTransparent="True"
                                                             Padding="10,0,0,0">
                                            <Label Text="{Binding Name}"
                                                   FontFamily="PressStart2PRegular"
                                                   FontSize="9"
                                                   TextColor="{StaticResource TextWhite}"
                                                   LineBreakMode="TailTruncation" />
                                            <Label Text="{Binding LastPlayedText}"
                                                   FontFamily="PressStart2PRegular"
                                                   FontSize="6"
                                                   TextColor="{StaticResource TextDim}" />
                                        </VerticalStackLayout>

                                        <!-- Delete — plain Button, no bevel needed at this size -->
                                        <Button Grid.Column="2"
                                                Text="✕"
                                                FontSize="13"
                                                TextColor="#cc6666"
                                                BackgroundColor="Transparent"
                                                BorderWidth="0"
                                                CornerRadius="0"
                                                WidthRequest="44"
                                                HeightRequest="44"
                                                VerticalOptions="Center"
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=DeleteSlotCommand}"
                                                CommandParameter="{Binding .}" />

                                    </Grid>
                                </Border>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </Grid>

            <!-- Footer: Back (left) | New World (right) -->
            <Grid Grid.Row="3"
                  ColumnDefinitions="*,16,*"
                  Margin="0,16,0,0">

                <!-- Back -->
                <Border Grid.Column="0" Style="{StaticResource VoxelButtonBevel}">
                    <Button Style="{StaticResource VoxelButton}"
                            Text="◀  Back"
                            Clicked="OnBackClicked">
                        <Button.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#7a7a7a" Offset="0.0"  />
                                <GradientStop Color="#525252" Offset="0.45" />
                                <GradientStop Color="#424242" Offset="0.55" />
                                <GradientStop Color="#303030" Offset="1.0"  />
                            </LinearGradientBrush>
                        </Button.Background>
                    </Button>
                </Border>

                <!-- New World — grass-green bevel signals a positive/creative action -->
                <Border Grid.Column="2">
                    <Border.StrokeThickness>0</Border.StrokeThickness>
                    <Border.Padding>3</Border.Padding>
                    <Border.HorizontalOptions>Center</Border.HorizontalOptions>
                    <Border.Shadow>
                        <Shadow Brush="#000000" Offset="4,4" Radius="0" Opacity="0.85" />
                    </Border.Shadow>
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#7ecf38" Offset="0.0" />
                            <GradientStop Color="#2a4a10" Offset="1.0" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <Button Style="{StaticResource VoxelButton}"
                            Text="+ New World"
                            Clicked="OnNewWorldClicked">
                        <Button.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#6ab82e" Offset="0.0"  />
                                <GradientStop Color="#4a8a1e" Offset="0.45" />
                                <GradientStop Color="#3a6a14" Offset="0.55" />
                                <GradientStop Color="#244a0a" Offset="1.0"  />
                            </LinearGradientBrush>
                        </Button.Background>
                    </Button>
                </Border>

            </Grid>
        </Grid>
    </Grid>
</ContentPage>
